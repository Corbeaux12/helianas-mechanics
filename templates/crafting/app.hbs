<div class="hm-crafting-app">

  {{!-- ===== LEFT SIDEBAR ===== --}}
  <nav class="hm-sidebar">

    <div class="hm-tabs" role="tablist">
      <button class="hm-tab {{#if (eq activeTab 'manufacturing')}}hm-tab--active{{/if}}"
              data-action="switchTab" data-tab="manufacturing" role="tab"
              title="{{localize 'HELIANAS.Manufacturing'}}">
        <i class="fa-solid fa-hammer"></i>
      </button>
      <button class="hm-tab {{#if (eq activeTab 'forge')}}hm-tab--active{{/if}}"
              data-action="switchTab" data-tab="forge" role="tab"
              title="{{localize 'HELIANAS.Forge'}}">
        <i class="fa-solid fa-fire"></i>
      </button>
      <button class="hm-tab {{#if (eq activeTab 'cooking')}}hm-tab--active{{/if}}"
              data-action="switchTab" data-tab="cooking" role="tab"
              title="{{localize 'HELIANAS.CookingLabel'}}">
        <i class="fa-solid fa-utensils"></i>
      </button>
    </div>

    <label class="hm-search">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input class="hm-search-input" type="search"
             placeholder="{{localize "HELIANAS.SearchPlaceholder"}}"
             value="{{searchQuery}}">
    </label>

    <ul class="hm-recipe-list" role="listbox">
      {{#each recipes}}
      <li class="hm-recipe-row {{#if selected}}hm-recipe-row--active{{/if}}"
          data-recipe-id="{{id}}" data-action="selectRecipe" role="option">
        <img class="hm-recipe-row__icon" src="{{img}}" alt="">
        <span class="hm-recipe-row__name">{{name}}</span>
      </li>
      {{else}}
      <li class="hm-recipe-empty">{{localize "HELIANAS.NoRecipes"}}</li>
      {{/each}}
    </ul>

    <p class="hm-recipe-count">── {{recipeCount}} {{localize "HELIANAS.RecipesLabel"}} ──</p>

  </nav>

  {{!-- ===== RIGHT DETAIL PANEL ===== --}}
  <div class="hm-detail">

    {{!-- Actor pickers (visible on every render) --}}
    <section class="hm-actor-row">
      <label class="hm-actor-label">
        <span>{{localize "HELIANAS.Crafter"}}</span>
        <select class="hm-actor-select-crafter">
          {{#each actors}}
          <option value="{{id}}" {{#if (eq id ../craftingActorId)}}selected{{/if}}>{{name}}</option>
          {{/each}}
        </select>
      </label>
      <label class="hm-actor-label">
        <span>{{localize "HELIANAS.InventoryHolder"}}</span>
        <select class="hm-actor-select-inventory">
          {{#each actors}}
          <option value="{{id}}" {{#if (eq id ../inventoryActorId)}}selected{{/if}}>{{name}}</option>
          {{/each}}
        </select>
      </label>
    </section>

    {{#if detail}}

      <div class="hm-detail__header">
        <img class="hm-detail__icon" src="{{detail.img}}" alt="">
        <div class="hm-detail__header-text">
          <h2 class="hm-detail__name">{{detail.name}}</h2>
          {{#if detail.rarity}}<span class="hm-detail__rarity">{{detail.rarity}}</span>{{/if}}
        </div>
      </div>

      {{!-- Forge path toggle --}}
      {{#if detail.isForge}}
      <div class="hm-path-toggle" role="tablist">
        <button class="hm-path-btn {{#if detail.isEnchantingPath}}hm-path-btn--active{{/if}}"
                data-action="switchPath" data-path="enchanting" type="button">
          <i class="fa-solid fa-wand-sparkles"></i> {{localize "HELIANAS.EnchantingPath"}}
        </button>
        <button class="hm-path-btn {{#if detail.isForgingPath}}hm-path-btn--active{{/if}}"
                data-action="switchPath" data-path="forging" type="button">
          <i class="fa-solid fa-fire"></i> {{localize "HELIANAS.ForgingPath"}}
        </button>
      </div>
      {{#if detail.missingBaseRecipe}}
      <p class="hm-warning">⚠ {{localize "HELIANAS.ForgeMissingBase"}}</p>
      {{/if}}
      {{/if}}

      {{!-- Unified ingredients block --}}
      {{#if detail.ingredients.length}}
      <section class="hm-section">
        <h4 class="hm-section__title">{{localize "HELIANAS.Ingredients"}}</h4>
        <ul class="hm-ingredients">
          {{#each detail.ingredients}}
          <li class="hm-ingredient" data-ingredient-id="{{id}}">
            <div class="hm-ingredient__name">{{name}}</div>
            <ul class="hm-components">
              {{#each components}}
              <li class="hm-component {{#if selected}}hm-component--selected{{/if}} {{#if available}}hm--found{{else}}hm--missing{{/if}}"
                  data-component-id="{{id}}" data-action="selectComponent">
                <img class="hm-component__icon" src="{{img}}" alt="">
                <div class="hm-component__body">
                  <div class="hm-component__name">{{name}}</div>
                  {{#if resourcePath}}
                    <div class="hm-component__meta">{{localize "HELIANAS.Resource"}}: <code>{{resourcePath}}</code></div>
                  {{else if tags.length}}
                    <div class="hm-component__meta">{{localize "HELIANAS.Tags"}}: {{#each tags}}<span class="hm-tag">{{this}}</span>{{/each}}</div>
                  {{/if}}
                </div>
                <div class="hm-component__qty">
                  <span class="hm-qty-have">{{inventoryQty}}</span>
                  <span class="hm-qty-sep">/</span>
                  <span class="hm-qty-need">{{quantity}}</span>
                  <span class="hm-component__status">{{#if available}}✓{{else}}✗{{/if}}</span>
                </div>
              </li>
              {{/each}}
            </ul>
          </li>
          {{/each}}
        </ul>
      </section>
      {{/if}}

      {{!-- Stats row --}}
      {{#if detail.isForgingPath}}
      <section class="hm-section hm-stats-dual">
        <div class="hm-stats-col">
          <h5 class="hm-stats-col__title">{{localize "HELIANAS.Manufacturing"}}</h5>
          {{#if detail.mfgStats.toolLabel}}
          <div class="hm-stat"><span>{{localize "HELIANAS.Tool"}}</span><span>{{detail.mfgStats.toolLabel}} ({{detail.mfgStats.abilityLabel}})</span></div>
          {{/if}}
          <div class="hm-stat"><span>{{localize "HELIANAS.DC"}}</span><span>{{detail.mfgStats.dc}}</span></div>
          <div class="hm-stat"><span>{{localize "HELIANAS.Time"}}</span><span>{{detail.mfgStats.timeHours}} {{localize "HELIANAS.Hours"}}</span></div>
          <p class="hm-formula">{{detail.mfgStats.formula}}</p>
        </div>
        <div class="hm-stats-col">
          <h5 class="hm-stats-col__title">{{localize "HELIANAS.Enchanting"}}</h5>
          <div class="hm-stat"><span>{{localize "HELIANAS.DC"}}</span><span>{{detail.encStats.dc}}</span></div>
          <div class="hm-stat"><span>{{localize "HELIANAS.Time"}}</span><span>{{detail.encStats.timeHours}} {{localize "HELIANAS.Hours"}}</span></div>
          <p class="hm-formula">{{detail.encStats.formula}}</p>
        </div>
        <div class="hm-stats-total">
          <span>{{localize "HELIANAS.TotalTime"}}</span>
          <span>{{detail.timeHours}} {{localize "HELIANAS.Hours"}}</span>
        </div>
      </section>
      {{else}}
      <section class="hm-section hm-stats">
        {{#if detail.toolLabel}}
        <div class="hm-stat">
          <span>{{localize "HELIANAS.Tool"}}</span>
          <span>{{detail.toolLabel}} ({{detail.abilityLabel}})</span>
        </div>
        {{/if}}
        <div class="hm-stat">
          <span>{{localize "HELIANAS.DC"}}</span>
          <span>{{detail.dc}}</span>
        </div>
        <div class="hm-stat">
          <span>{{localize "HELIANAS.Time"}}</span>
          <span>{{detail.timeHours}} {{localize "HELIANAS.Hours"}}</span>
        </div>
      </section>
      {{/if}}

      <hr class="hm-divider">

      {{!-- Essence slot --}}
      <section class="hm-section">
        <h4 class="hm-section__title">
          {{#if detail.essenceRequired}}
            {{localize "HELIANAS.EssenceRequired"}}
          {{else}}
            {{localize "HELIANAS.EssenceOptional"}}
          {{/if}}
        </h4>
        <div class="hm-essence-drop">
          {{#if detail.slottedEssence}}
            <span class="hm-essence-slotted">
              <i class="fa-solid fa-gem"></i> {{detail.slottedEssence.name}}
            </span>
            <button class="hm-essence-clear" data-action="clearEssence" type="button">✕</button>
          {{else}}
            <span class="hm-essence-placeholder">{{localize "HELIANAS.DropEssenceHere"}}</span>
          {{/if}}
        </div>
        {{#if detail.maxBoons}}
        <p class="hm-boon-cap">{{localize "HELIANAS.MaxBoonsCap"}}: {{detail.maxBoons}}</p>
        {{/if}}
      </section>

      <hr class="hm-divider">

      {{!-- Roll formula + result --}}
      <section class="hm-section hm-roll-section">
        {{#unless detail.isForgingPath}}
        <h4 class="hm-section__title">{{localize "HELIANAS.RollFormula"}}</h4>
        <p class="hm-formula">{{detail.rollFormula}}</p>
        {{/unless}}
        <div class="hm-roll-row">
          <label class="hm-roll-label" for="hm-roll-input">{{localize "HELIANAS.RollResult"}}</label>
          <input id="hm-roll-input" class="hm-roll-input" type="number"
                 min="1" max="40" placeholder="—">
        </div>
      </section>

      <div class="hm-actions">
        <button class="hm-btn-primary" data-action="craftItem" type="button"
                {{#unless detail.allAvailable}}title="{{localize 'HELIANAS.MissingIngredients'}}"{{/unless}}>
          {{detail.actionLabel}}
        </button>
      </div>

    {{else}}

      <div class="hm-detail__empty">
        <i class="fa-solid fa-anvil hm-detail__empty-icon"></i>
        <p>{{localize "HELIANAS.SelectRecipe"}}</p>
      </div>

    {{/if}}

  </div>{{!-- .hm-detail --}}

</div>{{!-- .hm-crafting-app --}}
